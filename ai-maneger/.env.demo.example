# Demo profile for Notion data source switching.
NOTION_ENV_LABEL=demo
TENANT_CONFIG_STORE_ENABLED=false
TENANT_CONFIG_DB_URL=
APP_CONFIG_ENCRYPTION_KEY=
TENANT_READ_ALLOWLIST=ootsuki,demo
TENANT_WRITE_ALLOWLIST=ootsuki,demo
TENANT_ADMIN_ALLOWLIST=ootsuki
DEV_AUTH_USER=local-dev

# Provide either NOTION_API_KEY or NOTION_API_TOKEN.
NOTION_API_KEY=your_demo_notion_token_here
# NOTION_API_TOKEN=

NOTION_PROJECT_DB_ID=your_demo_project_db_id_here
NOTION_OOTSUKI_PROJECT_PAGE_ID=your_demo_ootsuki_project_page_id_here
NOTION_OOTSUKI_DAILY_SALES_DB_ID=your_demo_daily_sales_db_id_here
NOTION_OOTSUKI_KPI_DB_ID=your_demo_kpi_db_id_here
NOTION_OOTSUKI_MEMO_DB_ID=your_demo_memo_db_id_here
NOTION_OOTSUKI_LINE_REPORT_PAGE_ID=your_demo_line_report_page_id_here
NOTION_OOTSUKI_PRODUCT_COST_DB_ID=your_demo_product_cost_db_id_here
NOTION_OOTSUKI_WEEKLY_ACTIONS_DB_ID=your_demo_weekly_actions_db_id_here

# Optional explicit demo tenant keys (when using shared base keys in same env)
NOTION_DEMO_API_KEY=your_demo_notion_token_here
NOTION_DEMO_PROJECT_DB_ID=your_demo_project_db_id_here
NOTION_DEMO_OOTSUKI_PROJECT_PAGE_ID=your_demo_ootsuki_project_page_id_here
NOTION_DEMO_OOTSUKI_DAILY_SALES_DB_ID=your_demo_daily_sales_db_id_here
NOTION_DEMO_OOTSUKI_KPI_DB_ID=your_demo_kpi_db_id_here
NOTION_DEMO_OOTSUKI_MEMO_DB_ID=your_demo_memo_db_id_here
NOTION_DEMO_OOTSUKI_LINE_REPORT_PAGE_ID=your_demo_line_report_page_id_here
NOTION_DEMO_OOTSUKI_PRODUCT_COST_DB_ID=your_demo_product_cost_db_id_here
NOTION_DEMO_OOTSUKI_WEEKLY_ACTIONS_DB_ID=your_demo_weekly_actions_db_id_here

NEXT_PUBLIC_APP_NAME=AI Maneger (Demo)
BASIC_AUTH_USER=demo
BASIC_AUTH_PASSWORD=replace_with_a_long_random_password

# Optional
# NOTION_API_VERSION=2022-06-28
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TEMPERATURE=
