# ========================================
# Railway 本番環境用 環境変数設定（サンプル）
# ========================================
# 
# 【使い方】
# 1. このファイルをコピーして .env を作成
# 2. 各値を実際の値に置き換える
# 3. Railway の環境変数タブに同じ値を設定
#

# ========================================
# 【必須】Notion API 設定
# ========================================
NOTION_API_KEY=secret_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ========================================
# 【必須】Notion Database IDs
# ========================================
NOTION_DB_CONVERSATION=700563e396c84f8f89adafb90c51ca3f
NOTION_DB_TRANSITIONS=your_transitions_db_id_here
NOTION_DB_NODES=your_nodes_db_id_here
NOTION_DB_MENU=258e9a7e-e5b7-8054-922d-e365bec99064
NOTION_DB_STORE=262e9a7e-e5b7-806e-911c-e966a0ccf7fe
NOTION_DB_HISTORY=262e9a7e-e5b7-8093-9967-d01fe7f9fe9e
NOTION_DATABASE_ID_MENU=258e9a7e-e5b7-8054-922d-e365bec99064
NOTION_DATABASE_ID_STORE=262e9a7e-e5b7-806e-911c-e966a0ccf7fe
NOTION_DATABASE_ID_CONVERSATION=700563e396c84f8f89adafb90c51ca3f
NOTION_DATABASE_ID_UNKNOWN_KEYWORDS=6cccf26b198645f2b08d71fb9b1d01f0
NOTION_PROJECT_PAGE_ID=262e9a7e-e5b7-80e2-accc-de2c79e0f502

# ========================================
# 【必須】OpenAI API 設定
# ========================================
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ========================================
# 【オプション】LangSmith トレーシング
# ========================================
LANGSMITH_API_KEY=ls__XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
LANGSMITH_PROJECT=ootsuki2-production
LANGCHAIN_TRACING_V2=true

# ========================================
# 【オプション】その他
# ========================================
SERPAPI_API_KEY=your_serpapi_key_here
CHROMA_PERSIST_DIR=/app/data/chroma/ootuki_restaurant
REQUIRE_CHROMA=false
LOG_LEVEL=INFO
ENVIRONMENT=production
