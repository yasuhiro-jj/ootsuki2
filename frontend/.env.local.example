# --- 既存チャット（FastAPI / プロキシ）---
NEXT_PUBLIC_API_URL=http://localhost:8011

# --- Notion API トークン（通常 API でメニュー・店舗 DB を読む）---
# NOTION_API_TOKEN= または NOTION_API_KEY= のどちらか
NOTION_API_KEY=ntn_xxxxxxxx

# --- Notion Database IDs（おおつき用）---
NOTION_DATABASE_ID_MENU=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NOTION_DATABASE_ID_STORE=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- OpenAI（回答生成用）---
OPENAI_API_KEY=sk-xxxxxxxx
# OPENAI_MODEL=gpt-4o-mini
# 0〜2。低いほど事実寄り（おかしさ対策）。未設定時は 0.55
# OPENAI_TEMPERATURE=0.55
# 追加のシステム指示（任意・長文OK）
# OPENAI_SYSTEM_EXTRA=電話番号は必ずデータの表記どおりに。

# --- 将来: Notion Agents API（Alpha アクセスが付いたら有効化）---
# NOTION_AGENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- 将来: ootsuki2 補助 API ---
# OOTSUKI2_API_BASE_URL=http://localhost:8011
# OOTSUKI2_API_KEY=
