# Platform API Environment Variables

# Database
PLATFORM_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ootsuki_platform

# JWT
JWT_SECRET_KEY=your-secret-key-change-this-in-production-use-openssl-rand-hex-32

# Encryption (for API keys)
ENCRYPTION_KEY=your-encryption-key-change-this-in-production

# Admin User (初回起動時に作成)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password

# Stripe (オプション)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Tenant Configuration
TENANT_BASE_URL=http://localhost
TENANT_PORT_START=8100
